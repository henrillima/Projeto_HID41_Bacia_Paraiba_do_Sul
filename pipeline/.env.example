# Copie este arquivo para .env e preencha com suas credenciais.
# NÃO commite o arquivo .env — ele já está no .gitignore.

# ---------------------------------------------------------------------------
# Supabase
# Encontre em: Supabase → Project Settings → API
# Use a SERVICE_ROLE key (não a anon key) — só o pipeline usa isso,
# nunca o frontend.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_SERVICE_KEY=<sua-service-role-key>

# ---------------------------------------------------------------------------
# ANA — HidroWebService REST (novo)
# Cadastro: enviar e-mail para hidro@ana.gov.br conforme descrito em
# docs/ANA_REST_API.md.
# ANA_API_USER = CPF (apenas dígitos) ou CNPJ usado no cadastro.
# ANA_API_PASS = senha recebida por e-mail (verificar caixa de spam).
# ---------------------------------------------------------------------------
ANA_API_BASE_URL=https://www.ana.gov.br/hidrowebservice
ANA_API_USER=<seu-cpf-sem-formatacao>
ANA_API_PASS=<sua-senha>
