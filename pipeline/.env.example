# Copie este arquivo para .env e preencha com suas credenciais do Supabase.
# NÃO commite o arquivo .env — ele já está no .gitignore.

# Encontre em: Supabase → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Use a SERVICE_ROLE key (não a anon key) — só o pipeline usa isso, nunca o frontend.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
